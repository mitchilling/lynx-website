{
  "name": "@lynx-js/lynx-doc",
  "version": "1.0.0",
  "scripts": {
    "build": "NODE_OPTIONS=--max-old-space-size=4096 RSPRESS_SSG_WORKER_THREAD_COUNT=2 rspress build",
    "check-docs": "python3 -m scripts.check_api_doc.index",
    "cspell:check": "cspell lint -c cspell.json \"docs/**/*.md(x)\"",
    "dev": "rspress dev",
    "fix-docs": "python3 -m scripts.check_api_doc.index --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "format:zhlint": "zhlint 'docs/zh/**/*.{md,mdx}' --fix",
    "gen:living-spec": "node scripts/lynx-living-spec.js",
    "prepare": "husky && pnpm --filter @lynx-js/lynx-compat-data run lint:keys && pnpm --filter @lynx-js/lynx-compat-data run gen-stats && pnpm prepare:lynx-compat-data && pnpm prepare:lynx-example-data && pnpm prepare:luna && pnpm prepare:lynx-ui-example-data && pnpm prepare:fetch-lynx-ui && pnpm prepare:sync-lynx-ui && pnpm prepare:lynx-ui-intros",
    "prepare:fetch-lynx-ui": "node scripts/fetch-lynx-ui.mjs",
    "prepare:luna": "LUNA_SOURCE_DIR=node_modules/@dugyu node scripts/luna-demo.js",
    "prepare:lynx-compat-data": "rm -rf docs/public/lynx-compat-data && ln -s $(pwd)/packages/lynx-compat-data docs/public/lynx-compat-data",
    "prepare:lynx-example-data": "node scripts/lynx-example.js",
    "prepare:lynx-ui-example-data": "EXAMPLES_DIR=packages/lynx-ui-example-packages/node_modules/@lynx-example REMOVE_LINK_PATH=false EXAMPLE_GIT_BASE_URL=https://github.com/lynx-family/lynx-ui/tree/main node scripts/lynx-example.js",
    "prepare:lynx-ui-intros": "node scripts/extract-lynx-ui-intros.js",
    "prepare:sync-lynx-ui": "node scripts/sync-lynx-ui-docs-to-shared.js",
    "preview": "rspress preview",
    "start": "rspress dev",
    "typedoc": "tsx ./scripts/typedoc/index.ts",
    "zhlint": "zhlint 'docs/zh/**/*.{md,mdx}'"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,md,mdx,json,yml,yaml,css,scss}": "prettier --write",
    "*.{md,mdx}": [
      "cspell lint -c cspell.json --no-must-find-files",
      "node scripts/ci/check-api-summary.mjs"
    ],
    "*.{js,jsx,ts,tsx,md,mdx,json,yml,yaml,html,svg,css,scss,less}": "node scripts/ci/check-asset-urls.mjs"
  },
  "dependencies": {
    "@douyinfe/semi-icons": "^2.74.0",
    "@douyinfe/semi-ui": "^2.75.0",
    "@dugyu/luna-demo-bundles": "0.1.0",
    "@dugyu/luna-stage": "0.2.1",
    "@dugyu/luna-studio": "0.1.3",
    "@lynx-js/go-web": "^0.5.1",
    "@lynx-js/lynx-core": "^0.1.3",
    "@lynx-js/web-core": "^0.20.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.5",
    "@radix-ui/react-dropdown-menu": "^2.1.5",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-radio-group": "^1.2.2",
    "@radix-ui/react-scroll-area": "^1.2.2",
    "@radix-ui/react-select": "^2.1.5",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.1.3",
    "@rspress/core": "2.0.6",
    "@shikijs/transformers": "^4.0.2",
    "class-variance-authority": "^0.7.1",
    "classnames": "^2.5.1",
    "clsx": "^1.2.1",
    "lucide-react": "^0.447.0",
    "mermaid": "^11.4.1",
    "motion": "^12.23.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.0",
    "react-copy-to-clipboard": "^5.1.0",
    "react-dom": "^18.3.0",
    "react-resizable-panels": "^2.1.7",
    "sonner": "^1.5.0",
    "swr": "^2.2.5",
    "tailwind-merge": "^2.5.2",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^1.1.2",
    "vscode-icons-js": "^11.6.1"
  },
  "devDependencies": {
    "@lynx-js/lynx-compat-data": "workspace:*",
    "@lynx-js/react": "^0.107.1",
    "@lynx-js/rspress-plugin-llms-postprocess": "workspace:*",
    "@lynx-js/testing-environment": "npm:@lynx-js/test-environment@0.0.1",
    "@mdn/minimalist": "^2.0.4",
    "@mdx-js/react": "^3.1.1",
    "@rsbuild/plugin-less": "^1.6.0",
    "@rsbuild/plugin-sass": "^1.5.0",
    "@rsbuild/plugin-svgr": "^1.3.0",
    "@rspress/plugin-algolia": "2.0.6",
    "@rspress/plugin-client-redirects": "2.0.6",
    "@rspress/plugin-llms": "2.0.6",
    "@rspress/plugin-rss": "2.0.6",
    "@rspress/plugin-sitemap": "2.0.6",
    "@types/node": "^18.11.17",
    "@types/react": "^18.3.0",
    "@types/react-copy-to-clipboard": "^5.0.1",
    "@types/react-dom": "^18.3.0",
    "@types/unist": "^3.0.3",
    "cspell": "^8.17.3",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.2",
    "prettier-plugin-packagejson": "^3.0.2",
    "react-render-to-markdown": "18.3.1",
    "rsbuild-plugin-google-analytics": "^1.0.3",
    "rsbuild-plugin-open-graph": "^1.0.2",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.19.4",
    "typedoc": "^0.28.0",
    "typedoc-plugin-expand-object-like-types": "^0.1.2",
    "typedoc-plugin-include-example": "^1.4.1",
    "typedoc-plugin-markdown": "~4.2.10",
    "typescript": "5.0.4",
    "unist-util-visit": "^5.0.0",
    "zhlint": "^0.8.2"
  },
  "packageManager": "pnpm@9.15.2+sha512.93e57b0126f0df74ce6bff29680394c0ba54ec47246b9cf321f0121d8d9bb03f750a705f24edc3c1180853afd7c2c3b94196d0a3d53d3e069d9e2793ef11f321"
}
